{
  "name": "manastack",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "ensure-data": "node scripts/ensure-data.mjs",
    "build:rarity": "node scripts/build-rarity-map.mjs",
    "patch:rarity": "node scripts/patch-rarity-from-scryfall-bulk.mjs",
    "patch:oracle": "node scripts/patch-oracle-from-scryfall-bulk.mjs",
    "build:standard": "node scripts/build-standard-pool.mjs",
    "build:sets": "node scripts/build-set-catalog.mjs",
    "build:trivia": "node scripts/generate-trivia-bulk.mjs && node scripts/generate-trivia-extra.mjs",
    "prebuild": "node scripts/ensure-vercel-data.mjs && node scripts/patch-oracle-from-scryfall-bulk.mjs",
    "build": "npm run build:trivia && tsc -b && vite build",
    "predev": "node scripts/ensure-data.mjs",
    "dev:kill": "node scripts/kill-dev-ports.mjs",
    "dev:fresh": "node scripts/kill-dev-ports.mjs && concurrently -n api,web -c blue,green \"npm run dev:server\" \"vite\"",
    "dev:server": "node server/index.mjs",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:server\" \"vite\"",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
